# Exclude these profiles from "finops profiles" (loaded at CLI startup; overrides .env and YAML)
# FINOPS_EXCLUDED_PROFILES=profile-a,profile-b,profile-c

# Inclusion filter: only these profiles are shown (allowlist)
# FINOPS_INCLUDED_ONLY_PROFILES=my-profile,other-profile

# OpenAI API key
FINOPS_OPENAI_API_KEY=sk-your-openai-api-key-here

# Agent model ID
FINOPS_AGENT_MODEL_ID=gpt-4o
# Temperature (gpt-5-mini only supports 1; default 0.2 for other models)
# FINOPS_AGENT_TEMPERATURE=1

# AWS Core MCP Server
FINOPS_MCP_CORE_ENABLED=true

# AWS Billing and Cost Management MCP Server (local via uvx)
FINOPS_MCP_BILLING_ENABLED=true

# AWS Documentation MCP Server
FINOPS_MCP_DOCUMENTATION_ENABLED=true

# AWS Pricing MCP Server (local via uvx)
FINOPS_MCP_PRICING_ENABLED=true

# Read-only guardrail: when true (default), blocks clearly mutating user requests before calling the agent.
FINOPS_READ_ONLY_GUARDRAIL_INPUT_ENABLED=true

# Verbose tool debug: when true (default), print tool/MCP inputs and responses in chat to help debug errors.
FINOPS_VERBOSE_TOOL_DEBUG=false

# PDF MCP Server
FINOPS_MCP_PDF_ENABLED=true

# Excel MCP Server
FINOPS_MCP_EXCEL_ENABLED=true

# CORS Origins
FINOPS_CORS_ORIGINS=http://localhost:5173

# Master Profile (AWS CLI profile name used as default)
FINOPS_MASTER_PROFILE=default

# Agent Warm on Startup
FINOPS_AGENT_WARM_ON_STARTUP=true
